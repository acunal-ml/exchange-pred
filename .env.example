# Template only — real values live in HF Spaces Secrets in production,
# or a local untracked .env in development. See docs/04.

ENVIRONMENT=local

# --- Cache backend: "redis" (local dev) or "ttl" (HF-safe fallback) ---
CACHE_BACKEND=ttl
REDIS_URL=redis://localhost:6379/0
CACHE_DEFAULT_TTL_SECONDS=300

# --- tvDatafeed (BIST). Optional: works anonymously with reduced symbols. ---
TVDATAFEED_USERNAME=
TVDATAFEED_PASSWORD=

# --- HF Hub (model/dataset artifact delivery) ---
HF_HUB_TOKEN=
HF_MODEL_REPO=
HF_DATASET_REPO=

LOG_LEVEL=INFO
